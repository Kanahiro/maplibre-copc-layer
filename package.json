{
	"name": "maplibre-copc-layer",
	"type": "module",
	"version": "0.1.7",
	"repository": {
		"type": "git",
		"url": "https://github.com/Kanahiro/maplibre-copc-layer.git"
	},
	"description": "A library for loading and rendering Cloud-Optimized Point Cloud (COPC) data in MapLibre GL JS using Three.js.",
	"license": "Apache-2.0",
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "vite build",
		"build:demo": "vite build --config vite.demo.config.ts",
		"dev": "vite",
		"test": "vitest",
		"typecheck": "tsc --noEmit",
		"release": "bumpp",
		"prepublishOnly": "pnpm run build"
	},
	"dependencies": {
		"copc": "^0.0.8",
		"proj4": "^2.15.0"
	},
	"peerDependencies": {
		"maplibre-gl": ">=5.0.0",
		"three": ">=0.150.0"
	},
	"devDependencies": {
		"@cloudflare/kv-asset-handler": "^0.4.2",
		"@types/node": "^25.5.0",
		"@types/proj4": "^2.5.6",
		"@types/three": "^0.173.0",
		"@typescript/native-preview": "7.0.0-dev.20260316.1",
		"bumpp": "^11.0.1",
		"lil-gui": "^0.21.0",
		"maplibre-gl": "^5.21.0",
		"three": "^0.173.0",
		"typescript": "^5.9.3",
		"vite": "^6.3.0",
		"vite-plugin-dts": "^4.5.0",
		"vitest": "^3.1.0"
	},
	"packageManager": "pnpm@10.32.1"
}
